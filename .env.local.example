# The Reading Room — Environment Variables

# Session signing secret (use a cryptographically secure random string, ~32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RR_SESSION_SECRET=your_session_secret_here

# Per-client password hashes
# Format: RR_PW_<CLIENTID>=<saltHex>:<hashHex>
# where <CLIENTID> is the client ID in uppercase with non-alphanumerics replaced by _
# Generate with: node scripts/rr-hash.mjs <client-id> "<password>"
# Example:
# RR_PW_PRECIOUS_ELECTROCHEM=<salt>:<hash>
